# Copy to .env for local development. In Railway, set these as environment
# variables on the service instead — this file is never read in production.

MONGO_URL=mongodb://localhost:27017
DB_NAME=bassani_internal

# Required — app refuses to start with the placeholder value.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256

ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

RESEND_API_KEY=
SENDER_EMAIL=noreply@bassanihealth.com
HEALTHCARE_EMAIL=healthcare@bassanihealth.com
PACKING_EMAILS=packing@bassanihealth.com,warehouse@bassanihealth.com

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@bassanihealth.com

INVOICE_START_NUMBER=34687
FACILITY_NAME=Bassani Health, 15 Innovation Drive, Midrand
FACILITY_ADDRESS=15 Innovation Drive, Midrand, 1685
VAT_NUMBER=4830271890
BANK_NAME=FNB
BANK_ACCOUNT=62834719283
BANK_BRANCH=250655

LOW_STOCK_DEFAULT_MIN=10
EXPIRY_WARNING_DAYS=60
FORECAST_LOOKBACK_WEEKS=8
REORDER_ALERT_DAYS=30

REQUIRE_2FA_ADMIN=false

# Comma-separated list of allowed origins. "*" is only acceptable before
# go-live — lock this to the real frontend domain(s) before launch (Phase 1.2).
CORS_ORIGINS=*

# Seeds the one super admin account on startup. Required on first deploy.
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=

# Static token for the packing floor display screen (no login, never expires).
# Generate with: openssl rand -hex 32
PACKING_BOARD_DISPLAY_TOKEN=
